# Copy to .env and fill in. Never commit the real .env file.

# --- Hugging Face Hub ---
MODEL_REPO=your-username/gpt2-style-emulation
HF_TOKEN=

# --- Model manager ---
MAX_RESIDENT_MODELS=3

# --- Generation defaults (Table I in the paper) ---
MAX_NEW_TOKENS=50
TOP_K=50
TOP_P=0.95
TEMPERATURE=0.9

# --- API behavior ---
RATE_LIMIT_PER_MINUTE=30
CORS_ORIGINS=["*"]
LOG_LEVEL=INFO

# --- UI (only used by ui/gradio_app.py) ---
API_BASE=http://localhost:8000/api/v1
GRADIO_PORT=7860
